# Database Configuration
# PostgreSQL connection string (Neon, Supabase, or self-hosted)
DATABASE_URL=postgresql://username:password@hostname:port/database?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://username:password@hostname:port/database?sslmode=require

# PostgreSQL Connection Parameters (alternative to DATABASE_URL)
PGHOST=your-database-host
PGHOST_UNPOOLED=your-database-host
PGUSER=your-database-user
PGDATABASE=your-database-name
PGPASSWORD=your-database-password

# Vercel Postgres (if using Vercel Postgres)
POSTGRES_URL=postgresql://username:password@hostname:port/database?sslmode=require
POSTGRES_URL_NON_POOLING=postgresql://username:password@hostname:port/database?sslmode=require
POSTGRES_USER=your-database-user
POSTGRES_HOST=your-database-host
POSTGRES_PASSWORD=your-database-password
POSTGRES_DATABASE=your-database-name
POSTGRES_URL_NO_SSL=postgresql://username:password@hostname:port/database
POSTGRES_PRISMA_URL=postgresql://username:password@hostname:port/database?connect_timeout=15&sslmode=require

# Email Service (Brevo - formerly Sendinblue)
# Required for receiving notifications when someone submits: contact form, resume request, project assessment.
# Use the API Key from Brevo: https://app.brevo.com/settings/keys/api (Settings → API Keys). Do NOT use the SMTP password.
# In Brevo: add and verify the sender (FROM_EMAIL) and ensure the domain is allowed.
BREVO_API_KEY=your_brevo_api_key_here
FROM_EMAIL=your_verified_sender_email@example.com
FROM_NAME=Ascendra Technologies
ADMIN_EMAIL=your_admin_email@example.com
# Optional: comma- or semicolon-separated extra addresses BCC’d on form/opportunity admin emails (contact, quote, resume, growth funnel lead, etc.). Primary recipient stays ADMIN_EMAIL.
# ADMIN_NOTIFICATION_EMAILS=partner@example.com,ops@example.com
# Optional: Brevo transactional webhooks (bounces + Email Hub opens/clicks). POST /api/webhooks/brevo?secret=<value>
# BREVO_WEBHOOK_SECRET=
# Email Hub — default reply-to and tracking domain labels (optional; sending uses verified senders from DB).
# BREVO_DEFAULT_REPLY_TO=
# BREVO_TRACKING_DOMAIN=
# Optional mapping hints for founder ↔ Brevo sender id (documentation / scripts; Hub stores senders in email_hub_senders).
# BREVO_SENDER_ANTHONY_ID=
# BREVO_SENDER_KRIS_ID=
# BREVO_SENDER_DENISHIA_ID=
#
# Email Hub — personal inbox sync (Phase 2). Separate OAuth apps from GOOGLE_CALENDAR_* (different Gmail API scopes).
# Gmail: enable Gmail API; authorized redirect URI (exact):
#   https://YOUR_DOMAIN/api/admin/email-hub/mailbox/gmail/callback
#   http://localhost:3000/api/admin/email-hub/mailbox/gmail/callback
# Microsoft: Azure app (multitenant), Mail.ReadWrite + Mail.Send + offline_access + User.Read; redirect URI:
#   https://YOUR_DOMAIN/api/admin/email-hub/mailbox/microsoft/callback
#   http://localhost:3000/api/admin/email-hub/mailbox/microsoft/callback
# Token encryption uses SCHEDULING_TOKEN_ENCRYPTION_KEY or SESSION_SECRET (same as scheduling integrations).
# EMAIL_HUB_GMAIL_CLIENT_ID=
# EMAIL_HUB_GMAIL_CLIENT_SECRET=
# EMAIL_HUB_MICROSOFT_CLIENT_ID=
# EMAIL_HUB_MICROSOFT_CLIENT_SECRET=
# Cron (optional): GET /api/cron/email-hub-inbox-sync with Authorization: Bearer <CRON_SECRET> — also in vercel.json every 15m.

# New client accounts (non–admin-request signup / OAuth): trial length in days (default 14, max 90).
# CLIENT_TRIAL_DAYS=14

# Client Growth System — server-side snapshot cache TTL in seconds (clamped 5–300; default 45). Table: client_growth_snapshots.
# CLIENT_GROWTH_SNAPSHOT_CACHE_TTL_SEC=45

# Agency Operating System — task acceptance: set to 1/true/yes so any approved admin may accept/decline/clarify on behalf of the assignee. Default is assignee-only.
# AGENCY_OS_ADMIN_TASK_ACCEPTANCE=1

# Ascendra SOP workflow — optional repo-relative (or absolute) JSON file deep-merged onto shared/ascendraSopWorkflowConfig.ts for AI assistant + GET /api/admin/agent/sop-workflow.
# Example: content/ascendra-sop-workflow.overrides.json
# ASCENDRA_SOP_WORKFLOW_JSON=

# Content strategy workflow — optional JSON deep-merged onto shared/contentStrategyWorkflowConfig.ts (Strategy admin page + AI context + GET /api/admin/content-studio/strategy-workflow).
# Example: content/ascendra-content-strategy.overrides.json
# ASCENDRA_CONTENT_STRATEGY_JSON=

# Behavior Intelligence — POST /api/behavior/ingest. If no secrets below, ingest is open (still IP rate-limited).
# BEHAVIOR_INGEST_SECRET=
# Browser SDK: same value as NEXT_PUBLIC_BEHAVIOR_INGEST_TOKEN (embeddable; rotate independently of server-only secret).
# BEHAVIOR_INGEST_PUBLIC_TOKEN=
# NEXT_PUBLIC_BEHAVIOR_INGEST_TOKEN=

# Stripe (invoices, deposits — optional until you use billing features)
# STRIPE_SECRET_KEY=sk_live_... or sk_test_...
# Webhook signing secret for POST /api/webhooks/stripe (invoice.paid → CRM timeline + client_invoices status + retainer subscription sync)
# STRIPE_WEBHOOK_SECRET=whsec_...
# Recurring retainer subscriptions (Growth platform): default recurring price id for POST /api/admin/retainer-subscriptions
# STRIPE_RETAINER_DEFAULT_PRICE_ID=price_...
# Default sales tax % for admin invoice form (0 = none). Subtotal × rate is added as a separate Stripe line.
# INVOICE_DEFAULT_TAX_PERCENT=0

# Proposal workflow: "Prepared by" name on client-facing proposals (e.g. Ascendra Technologies)
PROPOSAL_COMPANY_NAME=Ascendra Technologies

# DocuSign eSignature (optional — JWT grant for API; first use may require account admin consent)
# Rest base path: production https://NA4.docusign.net/restapi or demo https://demo.docusign.net/restapi (see account API URL)
# DOCUSIGN_INTEGRATION_KEY=
# DOCUSIGN_USER_ID= (GUID of impersonated user)
# DOCUSIGN_ACCOUNT_ID=
# DOCUSIGN_BASE_PATH=https://demo.docusign.net/restapi
# PEM with literal \n newlines, or base64:
# DOCUSIGN_RSA_PRIVATE_KEY=
# DOCUSIGN_RSA_PRIVATE_KEY_BASE64=
# DocuSign Connect HMAC for POST /api/webhooks/docusign (header X-DocuSign-Signature-1)
# DOCUSIGN_CONNECT_HMAC_SECRET=

# OpenAI API Key (for AI features like image generation, recommendations)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
#
# Google Gemini API (optional) — JavaScript SDK @google/genai. Key: https://aistudio.google.com/apikey
# Pro text default: gemini-3.1-pro-preview (Gemini 3 Pro preview was shut down Mar 2026 — migrate to 3.1 Pro).
# Live / realtime voice: gemini-3.1-flash-live-preview — use Live API (WebSocket), see https://ai.google.dev/gemini-api/docs/live-api
# GEMINI_API_KEY=
# GEMINI_MODEL_PRO=gemini-3.1-pro-preview
# GEMINI_MODEL_FLASH_LIVE=gemini-3.1-flash-live-preview
# Admin read-aloud (optional): Gemini preview TTS — default gemini-2.5-flash-preview-tts
# GEMINI_READ_ALOUD_TTS_MODEL=gemini-2.5-flash-preview-tts
#
# Growth OS (admin → Market research / content insights). Default model is gpt-4o-mini; if the API returns 403 “does not have access to model”, open Project settings on platform.openai.com or set a model your key can use:
# GOS_OPENAI_MODEL=gpt-4o
# GOS_INTELLIGENCE_MODE=mock
# Admin assistant widget + screenshot vision (default gpt-4o). If OpenAI returns 403 for that model, use e.g. gpt-4o-mini:
# OPENAI_ADMIN_AGENT_MODEL=gpt-4o-mini
# Optional: A/B experiment content insights (admin experiment detail → AI panel); defaults to OPENAI_ADMIN_AGENT_MODEL or gpt-4o-mini
# OPENAI_EXPERIMENT_INSIGHTS_MODEL=gpt-4o-mini
# Optional: model for admin Communications → design AI assist (default gpt-4o-mini)
# OPENAI_COMM_MODEL=gpt-4o-mini
# Optional: admin read-aloud uses tts-1 by default (works on typical API projects). For higher quality when your project has access:
# OPENAI_READ_ALOUD_MODEL=tts-1-hd
# Per-admin overrides (models + extra voice ids): Admin → Settings → Read-aloud (`admin_settings.tts_config`).

# Optional: refine CRM lifecycle status after rule-based journey automation (uses OPENAI_API_KEY). Off unless set.
# CRM_JOURNEY_AI_STATUS=true
# CRM_JOURNEY_AI_MODEL=gpt-4o-mini

# Ascendra Market Intelligence Engine (AMIE) — admin /admin/market-intelligence
# mock (default) = illustrative demand/economics from your form inputs; live = also surface Census/BLS adapter stubs when keys exist
# AMIE_DATA_MODE=mock
# GOOGLE_API_KEY — enable Google Places API (New) Text Search + Geocoding API on this key for real competition map
#   listings (names, ratings, review counts, addresses) tied to industry / service / location from the market form.
# CENSUS_API_KEY=
# BLS_API_KEY=

# Ascendra OS — force all gated public /api/market/* tools off regardless of Admin → Settings toggle (incident / pre-launch kill switch).
# ASCENDRA_OS_PUBLIC_ACCESS_LOCK=internal

# Optional: dedicated secret for HMAC-signed OAuth `state` (fallback: SESSION_SECRET, then FACEBOOK_APP_SECRET).
# OAUTH_STATE_SECRET=generate_a_long_random_string

# Optional: OAuth state cookie Domain (e.g. example.com) if invalid_state persists across www vs apex. Usually inferred from NEXT_PUBLIC_APP_URL.
# OAUTH_STATE_COOKIE_DOMAIN=example.com

# Brave Search API (optional — CRM social profile discovery uses public web results only; no on-network social scraping)
# https://brave.com/search/api/
# BRAVE_SEARCH_API_KEY=
# Also used by the admin mentor assistant for live web grounding when teaching (optional).
# Optional model override for re-ranking discovery candidates (default gpt-4o-mini)
# OPENAI_SOCIAL_RANK_MODEL=gpt-4o-mini

# Proposal prep — market intel synthesis (default gpt-4o-mini). Uses BRAVE_SEARCH_API_KEY for live snippets when set.
# OPENAI_PROPOSAL_MARKET_MODEL=gpt-4o-mini

# GitHub Integration (Optional)
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_USERNAME=your_github_username

# GitHub OAuth (for admin login - Optional)
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# Facebook Developer (OAuth / Login - Optional)
# Get from: https://developers.facebook.com/apps/ > App > Settings > Basic
# Facebook Login product → Settings: turn ON “Client OAuth Login” and “Web OAuth Login”.
# Valid OAuth Redirect URIs must list EVERY exact return URL (no trailing slash). Common set:
#   https://yoursite.com/api/auth/facebook/callback                    (site login, if used)
#   https://yoursite.com/api/admin/integrations/social/facebook/callback  (Content Studio · Facebook Page)
#   https://yoursite.com/api/admin/integrations/social/threads/callback   (Content Studio · Threads — add under Threads app valid OAuth URIs too)
# Local dev: same paths with http://localhost:3000 — add each variant you use (www vs non-www separately).
# Threads uses https://threads.net/oauth/authorize (not facebook.com/dialog/oauth). Scopes threads_basic, threads_content_publish.
# Set Threads App ID + secret from the app dashboard (Basic → Threads App ID / secret). Optional overrides:
# THREADS_APP_ID=your_threads_app_id
# THREADS_APP_SECRET=your_threads_app_secret
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
# Optional: override Graph API version for the browser SDK (default v21.0). Must look like v21.0
# NEXT_PUBLIC_FACEBOOK_GRAPH_VERSION=v21.0
# Optional: if you only expose a public app id for the client, it can be set here (otherwise FACEBOOK_APP_ID is read on the server for FB.init)
# NEXT_PUBLIC_FACEBOOK_APP_ID=your_facebook_app_id

# Google OAuth (Login with Google - Optional)
# Create credentials at: https://console.cloud.google.com/apis/credentials
# 1. Create/select a project > APIs & Services > Credentials.
# 2. Configure OAuth consent screen (User type: External for public; add your email as tester until verified).
# 3. Create credentials > OAuth client ID > Application type: Web application.
# 4. Authorized redirect URIs: add exactly:
#    - https://YOUR_PRODUCTION_DOMAIN/api/auth/google/callback   (e.g. https://yoursite.com/api/auth/google/callback)
#    - http://localhost:3000/api/auth/google/callback            (for local dev)
# 5. Authorized JavaScript origins (optional): https://YOUR_PRODUCTION_DOMAIN and http://localhost:3000
# 6. Copy Client ID and Client Secret here. Set NEXT_PUBLIC_APP_URL in production so callback URL matches.
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# Google Analytics 4 (Optional - for lead demographics in admin Website Analytics)
# Used to pull audience demographics (country, age, gender) into the Demographics tab.
# 1. In Google Cloud Console: create a project (or use existing), enable "Google Analytics Data API".
# 2. Create a Service Account (IAM → Service Accounts), grant it no extra roles (GA access is per-property).
# 3. In GA4: Admin → Property → Property Access Management → add the service account email as a Viewer.
# 4. Create a key for the service account (JSON), then copy client_email and the private_key (PEM) into env.
# Property ID: GA4 Admin → Property Settings → Property ID (numeric, e.g. 123456789).
GA4_PROPERTY_ID=your_ga4_property_id
GA4_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Private key from the JSON key file (single line with \n for newlines, or paste the full PEM block)
GA4_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Zoom (Schedule & start meetings from CRM - Optional)
# Create a Server-to-Server OAuth app at https://marketplace.zoom.us/ → Build App → Server-to-Server OAuth.
# Add scopes: meeting:write:admin (or meeting:write), meeting:read:admin. Copy Account ID, Client ID, Client Secret.
ZOOM_ACCOUNT_ID=your_zoom_account_id
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret

# Session Secret — required in production: at least 32 characters, not a placeholder.
# In production the app fails fast on boot if this is missing, too short, or a known default.
# Use: openssl rand -base64 32
SESSION_SECRET=your_secure_random_string_here

# Optional: HMAC for email open/click tracking tokens. If unset, SESSION_SECRET is used.
# In production you must set TRACKING_SIGNATURE_SECRET and/or SESSION_SECRET (see above).
# TRACKING_SIGNATURE_SECRET=

# Super-admin identities (optional). Comma-separated; case-insensitive.
# Defaults: username 5epmgllc and email from shared/super-admin-email.ts (5epmgllc@gmail.com) if unset.
# SUPER_ADMIN_USERNAMES=5epmgllc,backup_admin
# SUPER_ADMIN_EMAILS=you@example.com,backup@example.com
#
# Ensure that user exists in Postgres with is_admin + admin_approved (matches code owner):
#   npm run db:ensure-super-admin
# (Uses DATABASE_URL; loads .env.local when present.)

# Vercel Cron (e.g. /api/cron/growth-os): Authorization: Bearer <CRON_SECRET>
# When set, must be at least 16 characters (openssl rand -hex 24).
# On Vercel production, CRON_SECRET is required at boot (this repo ships vercel.json crons) unless you set:
# SKIP_VERCEL_CRON_SECRET=1
# If you deploy without any vercel.json crons and want to skip the CRON_SECRET boot check:
# VERCEL_CRONS_DISABLED=1
# CRON_SECRET=
#
# Ascendra OS storage retention — GET /api/cron/storage-retention (daily in vercel.json).
# Soft-deletes behavior sessions (and old draft funnel assets) after N days unless marked important/archived.
# Hard-deletes (and removes funnel files under public/uploads) after purge grace days in trash.
# ASCENDRA_RETENTION_DAYS=90
# ASCENDRA_RETENTION_PURGE_GRACE_DAYS=30
#
# Native scheduling (/book): confirmation + reminder emails use Brevo (BREVO_API_KEY + FROM_EMAIL).
# Guest manage/cancel links use NEXT_PUBLIC_APP_URL — set it to your real production origin.
# Reminder queue: GET /api/cron/scheduling (Authorization: Bearer CRON_SECRET) or bundled into GET /api/cron/growth-os.
# Optional model for /book AI assistant and admin “parse availability” (default gpt-4o-mini when OPENAI_API_KEY is set):
# OPENAI_SCHEDULING_MODEL=gpt-4o-mini
# Optional — Integrations only (external sync; native booking does not require these):
# Google Calendar: separate OAuth client from “Login with Google”. Enable Google Calendar API in Cloud Console.
# Authorized redirect URI (exact): https://YOUR_DOMAIN/api/admin/integrations/google-calendar/callback
# and http://localhost:3000/api/admin/integrations/google-calendar/callback for local dev.
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=
# No wrapping quotes needed; if you still see invalid_client locally + prod, paste again (same Web client ID + secret) and redeploy.
# Optional: dedicated secret for Calendar OAuth `state` signing (else OAUTH_STATE_SECRET → SESSION_SECRET → FACEBOOK_APP_SECRET).
# GOOGLE_CALENDAR_OAUTH_STATE_SECRET=
# Encrypts stored refresh token (recommended in production). Falls back to SESSION_SECRET if unset (min 16 chars).
# SCHEDULING_TOKEN_ENCRYPTION_KEY=
# CALENDLY_API_TOKEN=

# Admin Chat: Email uses Brevo (above). SMS is optional—only if you add Twilio.
# Default SMS recipient when "Also send via SMS" is used (optional; leave blank if you only use Brevo)
ADMIN_PHONE=

# SMS (Optional - only if you want admin chat to send via SMS; otherwise skip. Email = Brevo.)
# Revenue Ops: inbound SMS → /api/webhooks/twilio/sms ; voice status (missed call) → /api/webhooks/twilio/voice
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# Use either a From number OR a Messaging Service SID (not both required in code; Messaging Service is preferred when set).
# TWILIO_FROM_NUMBER=
# TWILIO_MESSAGING_SERVICE_SID=
# Optional: Twilio delivery status callback URL for outbound SMS (configure in Twilio or pass per-message)
# TWILIO_STATUS_CALLBACK_URL=
# Tracked booking links in SMS (HMAC for /go/book/[token]); generate: openssl rand -hex 32
# REVENUE_OPS_BOOKING_LINK_SECRET=
# Public site URL for absolute tracked links in SMS (optional; else relative /go/book/... is used)
# NEXT_PUBLIC_APP_URL=https://your-domain.com
# Fallback scheduler URL if not set in Growth OS → Revenue ops settings
# DEFAULT_BOOKING_URL=

# Push Notifications (Optional - Web Push API, for admin chat "push to device")
# Generate keys using: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here

# Admin dashboard — “Development updates” digest (production reads markdown from GitHub)
# On Vercel, VERCEL_GIT_REPO_OWNER + VERCEL_GIT_REPO_SLUG are set for you; the app builds:
#   https://raw.githubusercontent.com/<owner>/<slug>/<ref>/content/development-updates.md
# with ref = DEVELOPMENT_UPDATES_GITHUB_REF (default main). Override the full URL if needed:
# DEVELOPMENT_UPDATES_RAW_URL=https://raw.githubusercontent.com/YourOrg/YourRepo/main/content/development-updates.md
# Private repo or API fallback: DEVELOPMENT_UPDATES_GITHUB_TOKEN or GITHUB_TOKEN
# Multi-branch merge (unusual): DEVELOPMENT_UPDATES_MULTI_BRANCH=true
# When you ship user-facing features to main, append a dated ## section to content/development-updates.md in the same push.

# Content Studio — scheduled social publish (Vercel cron /api/cron/content-studio-publish, every 10m in vercel.json)
# Requires CRON_SECRET (same as other crons). Calendar platformTargets use adapter keys: manual, facebook_page,
# linkedin, x, webhook_hub, brevo_notify, etc.
# Facebook Page: FACEBOOK_ACCESS_TOKEN + FACEBOOK_PAGE_ID.
# LinkedIn: Integrations OAuth (LINKEDIN_CLIENT_ID + LINKEDIN_CLIENT_SECRET) loads your profile + company pages you admin; or use LINKEDIN_ACCESS_TOKEN + LINKEDIN_AUTHOR_URN (urn:li:person:… or urn:li:organization:…).
# LinkedIn Developer app: enable products for Sign In + posting; org listing may require Community Management / Marketing API access per LinkedIn.
# Optional: LINKEDIN_OAUTH_SCOPES=openid profile w_member_social (default also requests w_organization_social r_organization_admin).
# X: X_OAUTH2_ACCESS_TOKEN (or TWITTER_OAUTH2_ACCESS_TOKEN); user token with tweet.write. Optional X_TWEET_MAX_CHARS=4000.
# Webhook hub (Buffer/Make/Zapier): CONTENT_STUDIO_PUBLISH_WEBHOOK_URL; optional CONTENT_STUDIO_PUBLISH_WEBHOOK_SECRET (sha256 HMAC).
# Brevo notify-only: add brevo_notify to targets; uses BREVO_API_KEY + FROM_EMAIL; optional CONTENT_STUDIO_BREVO_NOTIFY_TO (else ADMIN_EMAIL).
# Default: linked document must be approvalStatus=approved before cron publishes.
# CONTENT_STUDIO_SCHEDULED_REQUIRE_APPROVAL=0

# Ascendra Offer + Persona Intelligence (internal admin): tables `marketing_personas`,
# `ascendra_script_templates`, `ascendra_lead_magnets` — apply with npm run db:push; seed personas with npm run db:seed.

# --- Paid Growth / PPC (Ascendra OS) — server-only secrets; see Docs/implementation/PAID-GROWTH-MODULE.md ---
# Google Ads API (OAuth refresh + developer token). Campaign mutate via API is documented; connection test uses refresh flow.
# GOOGLE_ADS_DEVELOPER_TOKEN=
# GOOGLE_ADS_CLIENT_ID=
# GOOGLE_ADS_CLIENT_SECRET=
# GOOGLE_ADS_REFRESH_TOKEN=
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=
# GOOGLE_ADS_DEFAULT_CUSTOMER_ID=
# GOOGLE_ADS_USE_TEST_ACCOUNT=0
# Meta Marketing API — system user or long-lived token with ads_management; version configurable.
# META_APP_ID=
# META_APP_SECRET=
# META_SYSTEM_USER_ACCESS_TOKEN=
# META_AD_ACCOUNT_ID=
# META_BUSINESS_ID=
# META_GRAPH_API_VERSION=v25.0
# META_WEBHOOK_VERIFY_TOKEN=
# Tracking (readiness scoring + landing URLs) — reuse existing public IDs when set:
# Google Tag Manager container id (public). Example: GTM-KGDGP4F4
# NEXT_PUBLIC_GTM_ID=GTM-KGDGP4F4
# NEXT_PUBLIC_META_PIXEL_ID=
# GOOGLE_TAG_MANAGER_SERVER_CONTAINER_URL=
# Optional sync cadence (document only until a job runner is wired):
# SYNC_JOBS_ENABLED=false
# PPC_SYNC_INTERVAL_MINUTES=30
# Client portal: sanitized PPC summary API (`GET /api/client/ppc-summary`) when user has portal eligibility.
# ASCENDRA_PPC_CLIENT_SUMMARY_ENABLED=false
# Comma-separated campaign IDs visible in that API (internal ops configures per deployment).
# ASCENDRA_PPC_CLIENT_VISIBLE_CAMPAIGN_IDS=

# Upstash Redis (Optional — global rate limits across serverless instances)
# Create a Redis database at https://console.upstash.com → copy REST URL + REST TOKEN.
# When set, public APIs (e.g. GOS client report) use Upstash sliding-window limits in production.
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token_here

# Local dev — git hook appends content/development-updates.md after each commit (see scripts/dev-log-commit.mjs).
# Installed by npm install (prepare) or npm run dev:install-hooks. Skips merge commits and when CI=true.
# Flags are also read from .env.local by the hook script (no need to export in the shell on Windows).
# SKIP_DEV_LOG_COMMIT=1
# ASCENDRA_DEV_LOG_COMMITS=0
# ASCENDRA_DEV_LOG_QUIET=1

# AFN Timeline Live (Phase 9) — server-provisioned rooms; pick one provider or both (LiveKit with Daily failover).
# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# DAILY_API_KEY=
# Optional: detected for product messaging only (no server room create yet)
# ZOOM_VIDEO_SDK_KEY=

# Application Settings
NODE_ENV=development
# Google Analytics 4 measurement ID (gtag.js). Default: G-5FTCQF2JH4. Set to empty to disable.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-5FTCQF2JH4
# Google Ads conversion tag (gtag destination, e.g. AW-11419169823). Same root layout snippet as GA; set empty to disable.
# NEXT_PUBLIC_GOOGLE_ADS_ID=AW-11419169823
# Offer Audit / valuation funnel: optional per-action send_to (full value AW-xxx/Label). Overrides the fallback below when set.
# NEXT_PUBLIC_GOOGLE_ADS_SEND_TO_OFFER_AUDIT_STARTED=
# NEXT_PUBLIC_GOOGLE_ADS_SEND_TO_OFFER_AUDIT_SUBMITTED=
# NEXT_PUBLIC_GOOGLE_ADS_SEND_TO_LEAD_CREATED=
# NEXT_PUBLIC_GOOGLE_ADS_SEND_TO_STRATEGY_CALL=
# /market-score funnel: fire gtag('event','conversion',{ send_to: '...' }) after successful submit (full AW-xxx/label).
# NEXT_PUBLIC_GOOGLE_ADS_MARKET_SCORE_SEND_TO=
# Optional: label-only envs (paired with NEXT_PUBLIC_GOOGLE_ADS_ID) when you prefer not to paste full send_to strings.
# NEXT_PUBLIC_GOOGLE_ADS_CV_OFFER_AUDIT_STARTED=
# NEXT_PUBLIC_GOOGLE_ADS_CV_OFFER_AUDIT_SUBMITTED=
# NEXT_PUBLIC_GOOGLE_ADS_CV_LEAD_CREATED=
# NEXT_PUBLIC_GOOGLE_ADS_CV_STRATEGY_CALL=
# Fallback for submitted + lead conversions when per-action send_to / CV_* is unset (combine id + label from Google Ads UI).
# NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=
# Canonical site URL: used for Open Graph / Facebook / LinkedIn / X link previews, Twitter cards,
# canonical links, sitemap/robots, and password reset emails.
# Set NEXT_PUBLIC_APP_URL to your real production origin (https://...) so shared links show the
# correct title, description, and og-ascendra.png (logo + tagline). After deploy, re-scrape URLs in
# Facebook Sharing Debugger, X Card Validator, and LinkedIn Post Inspector if previews look stale.
# On Vercel, VERCEL_PROJECT_PRODUCTION_URL / VERCEL_URL are used as fallbacks when building metadata
# if NEXT_PUBLIC_* are unset (still recommended to set NEXT_PUBLIC_APP_URL for the browser bundle).
# Also used to set Server Actions allowedOrigins (CSRF) for that hostname in next.config.js.
NEXT_PUBLIC_APP_URL=https://yoursite.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Optional — Admin → Deployment env: push variables to Vercel from the dashboard (super user only).
# Create a token at https://vercel.com/account/tokens with access to the project. Prefer VERCEL_API_TOKEN
# in local .env.local only; do not commit. Team projects need VERCEL_TEAM_ID (Settings → Team ID).
# VERCEL_API_TOKEN=
# VERCEL_PROJECT_ID=prj_xxxxxxxx        # or use VERCEL_PROJECT_NAME=your-project-slug
# VERCEL_PROJECT_NAME=
# VERCEL_TEAM_ID=team_xxxxxxxx

# Admin User Setup (for scripts only - never commit real values)
# Used by scripts/create-admin.ts, scripts/reset-admin-password.ts, scripts/verify-password.ts
ADMIN_EMAIL=your-admin-email@example.com
ADMIN_PASSWORD=your-secure-password

# Seed Admin User (for server/seed.ts only - optional)
SEED_ADMIN_EMAIL=your-admin-email@example.com
SEED_ADMIN_PASSWORD=your-secure-password
